// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"   // ← Removed for now (recommended)
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String         @id @default(uuid())
  username     String         @unique
  email        String         @unique
  password     String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique                    // Added @unique
  userId    String
  createdAt DateTime @default(now())            // Good to track
  expiresAt DateTime                               // Recommended

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}